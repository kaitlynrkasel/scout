# Copy this file to .env.local and fill in your keys.
# These are the same two keys your Apps Script tools use.

# Tavily web-search key (https://tavily.com) — used for discovery + contact finding
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxx

# Anthropic API key (https://console.anthropic.com) — used for extraction + drafting
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Optional: override the model (defaults to claude-sonnet-4-6, the one your scripts use)
# SCOUT_MODEL=claude-sonnet-4-6

# Supabase (accounts + password-protected profiles). Leave these blank to keep the
# app in per-browser mode with no login. From your Supabase project:
# Project Settings → API → Project URL and the "anon public" key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Outlook / Microsoft 365 "connect your mailbox" (optional; mirrors Gmail). Register
# an app at https://portal.azure.com → App registrations. Supported account types:
# "Accounts in any org directory and personal Microsoft accounts". Add a Web redirect
# URI of <your-origin>/api/outlook/callback (e.g. http://localhost:3000/api/outlook/callback
# and your production URL). Add delegated Graph permissions Mail.ReadWrite + Mail.Send,
# and create a client secret. Leave blank to hide the Outlook option.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Optional: restrict to a single tenant (defaults to "common" = work + personal accounts).
# MICROSOFT_TENANT=common
