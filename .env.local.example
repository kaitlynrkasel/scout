# Copy this file to .env.local and fill in your keys.
# These are the same two keys your Apps Script tools use.

# Tavily web-search key (https://tavily.com) — used for discovery + contact finding
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxx

# Anthropic API key (https://console.anthropic.com) — used for extraction + drafting
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Optional: override the model (defaults to claude-sonnet-4-6, the one your scripts use)
# SCOUT_MODEL=claude-sonnet-4-6

# Owner-only Insights tab. Comma-separated list of emails allowed to see
# aggregate denial / acceptance data across all users. Anyone else signing in
# never sees the tab or the API route.
# SCOUT_OWNER_EMAILS=you@example.com

# Vercel Cron auth for the /api/cron/send-scheduled job that drains the
# scheduled_sends queue. Generate a long random string (e.g. `openssl rand -hex 32`)
# and set the same value in your Vercel project's env vars. Vercel sends this as
# `Authorization: Bearer <CRON_SECRET>` on every cron invocation; unauthenticated
# hits get 401.
CRON_SECRET=

# Supabase (accounts + password-protected profiles). Leave these blank to keep the
# app in per-browser mode with no login. From your Supabase project:
# Project Settings → API → Project URL and the "anon public" key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key (Project Settings → API → "service_role"). Server-only; powers
# teams, the anti-overexposure ledger, and the Stripe webhook + search metering.
# NEVER expose this to the browser. Required for subscriptions/metering to work.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe subscriptions (Starter $15/mo → 30 searches, Pro $30/mo → 60 searches).
# Leave blank to keep discovery unmetered. From https://dashboard.stripe.com:
#  - Secret key: Developers → API keys ("Secret key").
#  - Price ids: create two recurring monthly Products/Prices, copy each price id.
#  - Webhook secret: Developers → Webhooks → add endpoint
#    <your-origin>/api/billing/webhook, subscribe to checkout.session.completed,
#    customer.subscription.created/updated/deleted, invoice.paid; copy its
#    "Signing secret". (Locally: `stripe listen --forward-to
#    localhost:3000/api/billing/webhook` prints one.)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
# Base URL for Stripe Checkout/Portal redirects (no trailing slash). Falls back to
# the request origin if unset; set it in production, e.g. https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=

# Outlook / Microsoft 365 "connect your mailbox" (optional; mirrors Gmail). Register
# an app at https://portal.azure.com → App registrations. Supported account types:
# "Accounts in any org directory and personal Microsoft accounts". Add a Web redirect
# URI of <your-origin>/api/outlook/callback (e.g. http://localhost:3000/api/outlook/callback
# and your production URL). Add delegated Graph permissions Mail.ReadWrite + Mail.Send,
# and create a client secret. Leave blank to hide the Outlook option.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Optional: restrict to a single tenant (defaults to "common" = work + personal accounts).
# MICROSOFT_TENANT=common
